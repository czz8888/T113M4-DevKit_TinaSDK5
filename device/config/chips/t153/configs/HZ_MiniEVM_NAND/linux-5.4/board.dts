&gpadc2 {
	pinctrl-0 = <&gpadc2_pins_default>;
	pinctrl-1 = <&gpadc2_pins_sleep>;
	channel_num = <4>;
	only_used_for_gpadc;
	channel_select = <0xf>;
	//channel_data_select = <0xf>;
	status = "okay";

	/* 通道定义 */
	channel@0 { /* 不要删除此节点 */
		reg = <0>;
	};

	channel@1 { /* 不要删除此节点 */
		reg = <1>;
	};

	channel@2 { /* 不要删除此节点 */
		reg = <2>;
	};

	channel@3 { /* 不要删除此节点 */
		reg = <3>;
	};
};

&gpadc3 {
	channel_num = <2>;
	channel_select = <3>;
	channel_data_select = <0>;
	channel_compare_select = <0>;
	channel_cld_select = <3>;
	channel_chd_select = <0>;
	channel0_compare_lowdata = <1700000>;
	channel0_compare_higdata = <1200000>;
	channel1_compare_lowdata = <460000>;
	channel1_compare_higdata = <1200000>;
	status = "disabled";
};

&rfkill {
	compatible = "allwinner,sunxi-rfkill";
	chip_en;
	power_en;
	pinctrl-0;
	pinctrl-names;
	status = "disabled";

	/* wlan session */
	wlan {
		compatible    = "allwinner,sunxi-wlan";
		wlan_busnum   = <0x1>;
		wlan_regon    = <&pio PG 13 GPIO_ACTIVE_HIGH>;
		wlan_hostwake = <&pio PG 11 GPIO_ACTIVE_HIGH>;
		wakeup-source;
		regulator-boot-on;
		regulator-always-on;
		status        = "disabled";
	};

	/* bt session */
	bt {
		compatible    = "allwinner,sunxi-bt";
		bt_rst_n      = <&pio PG 12 GPIO_ACTIVE_LOW>;
		status        = "disabled";
	};

};

&btlpm {
	compatible  = "allwinner,sunxi-btlpm";
	uart_index  = <0x1>;
	bt_wake     = <&pio PG 14 GPIO_ACTIVE_HIGH>;
	bt_hostwake = <&pio PG 15 GPIO_ACTIVE_HIGH>;
	/* wakeup-source; */
	status      = "disabled";
};

&addr_mgt {
	compatible = "allwinner,sunxi-addr_mgt";
	type_addr_wifi = <0x0>;
	type_addr_bt   = <0x0>;
	type_addr_eth  = <0x0>;
	status = "okay";
};

&irrx0 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&irrx0_pins_default>;
	pinctrl-1 = <&irrx0_pins_sleep>;
	status = "disabled";
};

&irrx1 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&irrx1_pins_default>;
	pinctrl-1 = <&irrx1_pins_sleep>;
	status = "disabled";
};

&irrx2 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&irrx2_pins_default>;
	pinctrl-1 = <&irrx2_pins_sleep>;
	status = "disabled";
};

&irrx3 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&irrx3_pins_default>;
	pinctrl-1 = <&irrx3_pins_sleep>;
	status = "disabled";
};

&irtx0 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&irtx0_pins_default>;
	pinctrl-1 = <&irtx0_pins_sleep>;
	status = "disabled";
};

&ledc  {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&ledc_pins_default>;
	pinctrl-1 = <&ledc_pins_sleep>;
	led_count = <32>;
	output_mode = "GRB";
	reset_ns = <84>;
	t1h_ns = <800>;
	t1l_ns = <320>;
	t0h_ns = <300>;
	t0l_ns = <800>;
	wait_time0_ns = <84>;
	wait_time1_ns = <84>;
	wait_data_time_ns = <600000>;
	status = "disabled";
};

/* audio dirver module -> audio codec */
&codec {
	tx-hub-en;

	dac-vol		= <63>;		/* default value:63 range:0->63 */
	dacl-vol	= <160>;	/* default value:160 range:0->255 */
	lineout-gain	= <31>;		/* default value:31 range:0->31 */

	pa-pin-max	= <1>;
	pa-pin-0	= <&pio PG 10 GPIO_ACTIVE_HIGH>;
	pa-pin-level-0	= <1>;
	pa-pin-msleep-0	= <0>;

	status = "disabled";
};

&codec_plat {
	status = "disabled";
};

&codec_mach {
	status = "disabled";
	soundcard-mach,cpu {
		sound-dai = <&codec_plat>;
	};
	soundcard-mach,codec {
		sound-dai = <&codec>;
	};
};

/* audio dirver module -> owa */
&owa_plat {
	/* pinctrl-used; */
	/* pinctrl-names	= "default","sleep"; */
	/* pinctrl-0	= <&owa_pins_a>; */
	/* pinctrl-1	= <&owa_pins_b>; */
	tx-hub-en;

	status		= "disabled";
};

&owa_mach {
	status		= "disabled";
	soundcard-mach,cpu {
		sound-dai = <&owa_plat>;
	};
	soundcard-mach,codec {
	};
};

/* audio dirver module -> DMIC */
&dmic_plat {
	rx-chmap	= <0x76543210>;
	data-vol	= <0xB0>;
	rxdelaytime	= <0>;
	pinctrl-used;
	pinctrl-names	= "default","sleep";
	pinctrl-0	= <&dmic_pins_a>;
	pinctrl-1	= <&dmic_pins_b>;
	rx-sync-en;
	status		= "disabled";
};

&dmic_mach {
	status		= "disabled";
	soundcard-mach,cpu {
		sound-dai = <&dmic_plat>;
	};
	soundcard-mach,codec {
	};
};

/* audio dirver module -> I2S/PCM */
&i2s0_plat {
	tdm-num		= <0>;
	tx-pin		= <0>;
	rx-pin		= <0>;
	/* pinctrl-used; */
	/* pinctrl-names	= "default","sleep"; */
	/* pinctrl-0	= <&i2s0_pins_a &i2s0_pins_c>; */
	/* pinctrl-1	= <&i2s0_pins_b &i2s0_pins_d>; */
	tx-hub-en;
	rx-sync-en;
	status		= "disabled";
};

&i2s0_mach {
	soundcard-mach,format		= "i2s";
	soundcard-mach,frame-master	= <&i2s0_cpu>;
	soundcard-mach,bitclock-master	= <&i2s0_cpu>;
	/* soundcard-mach,frame-inversion; */
	/* soundcard-mach,bitclock-inversion; */
	soundcard-mach,slot-num		= <2>;
	soundcard-mach,slot-width	= <32>;
	soundcard-mach,capture-only;
	status		= "disabled";
	i2s0_cpu: soundcard-mach,cpu {
		sound-dai = <&i2s0_plat>;
		/* note: pll freq = 24.576M or 22.5792M * pll-fs */
		soundcard-mach,pll-fs	= <1>;
		/* note:
		 * mclk freq = mclk-fs * 12.288M or 11.2896M	(when mclk-fp ture)
		 * mclk freq = mclk-fs * pcm rate		(when mclk-fp false)
		 */
		soundcard-mach,mclk-fs	= <1>;
		soundcard-mach,mclk-fp;
	};
	i2s0_codec: soundcard-mach,codec {
		soundcard-mach,pll-fs   = <1>;
	};
};

&i2s1_plat {
	tdm-num		= <1>;
	tx-pin		= <0>;
	rx-pin		= <0>;
	/* pinctrl-used; */
	/* pinctrl-names= "default","sleep"; */
	/* pinctrl-0	= <&i2s1_pins_a &i2s1_pins_b &i2s1_pins_c &i2s1_pins_d>; */
	/* pinctrl-1	= <&i2s1_pins_e>; */
	tx-hub-en;
	rx-sync-en;
	status		= "disabled";
};

&i2s1_mach {
	soundcard-mach,format		= "dsp_a";
	soundcard-mach,frame-master	= <&i2s1_cpu>;
	soundcard-mach,bitclock-master	= <&i2s1_cpu>;
	/* soundcard-mach,frame-inversion; */
	soundcard-mach,bitclock-inversion;
	soundcard-mach,slot-num		= <2>;
	soundcard-mach,slot-width	= <16>;
	status		= "disabled";
	i2s1_cpu: soundcard-mach,cpu {
		sound-dai = <&i2s1_plat>;
		soundcard-mach,pll-fs	= <1>;
		soundcard-mach,mclk-fs	= <0>;
	};
	i2s1_codec: soundcard-mach,codec {
	};
};

&i2s2_plat {
	tdm-num		= <2>;
	tx-pin		= <0 1 2 3>;

	rx-pin		= <0>;
	/* pinctrl-used; */
	/* pinctrl-names= "default","sleep"; */
	/* pinctrl-0	= <&i2s2_pins_a>; */
	/* pinctrl-1	= <&i2s2_pins_b>; */
	tx-hub-en;
	rx-sync-en;
	/* edp not need dai-type */
	status		= "disabled";
};

&i2s2_mach {
	soundcard-mach,format		= "i2s";
	soundcard-mach,frame-master	= <&i2s2_cpu>;
	soundcard-mach,bitclock-master	= <&i2s2_cpu>;
	/* soundcard-mach,frame-inversion; */
	/* soundcard-mach,bitclock-inversion; */
	soundcard-mach,slot-num		= <2>;
	soundcard-mach,slot-width	= <32>;
	status		= "disabled";
	i2s2_cpu: soundcard-mach,cpu {
		sound-dai = <&i2s2_plat>;
		soundcard-mach,pll-fs	= <1>;
		/* edp mclk: 512fs */
		soundcard-mach,mclk-fs	= <0>;
	};
	i2s2_codec: soundcard-mach,codec {

	};
};


&gmac0_phy0 {
	compatible = "ethernet-phy-id4f51.e91b";
	reg = <0x0>;
	max-speed = <1000>;
	reset-gpios = <&pio PA 14 GPIO_ACTIVE_LOW>;
	/* PHY datasheet rst time */
	reset-assert-us = <10000>;
	reset-deassert-us = <30000>;
};

&gmac1_phy0 {
	compatible = "ethernet-phy-id4f51.e91b";
	reg = <0x0>;
	max-speed = <1000>;
	reset-gpios = <&pio PG 5 GPIO_ACTIVE_LOW>;
	/* PHY datasheet rst time */
	reset-assert-us = <10000>;
	reset-deassert-us = <30000>;
};

&gmac0 {
	phy-mode = "rgmii";
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&gmac0_pins_default>;
	pinctrl-1 = <&gmac0_pins_sleep>;
	tx-delay = <10>;
        rx-delay = <10>;
	/delete-property/ aw,soc-phy25m;
	/delete-property/ aw,rgmii-clk-ext;
	status = "okay";
};

&gmac1 {
	phy-mode = "rgmii";
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&gmac1_pins_default>;
	pinctrl-1 = <&gmac1_pins_sleep>;
	tx-delay = <10>;
        rx-delay = <10>;
	/delete-property/ aw,soc-phy25m;
	/delete-property/ aw,rgmii-clk-ext;
	status = "okay";
};

&dma1 {
       status="okay";
};

&rtp {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&rtp_pins_default>;
	pinctrl-1 = <&rtp_pins_sleep>;
	allwinner,tp-sensitive-adjust = <0xa>;
	allwinner,filter-type = <0x3>;
	status = "disabled";
};


&csi_mclk2_pins_a {
	pins = "PA6";
	function = "ncsi";
	drive-strength = <20>;
};

&csi_mclk2_pins_b {
	pins = "PA6";
	function = "gpio_in";
};

&ncsi_8bit_pins_a {
	pins = 	"PA7", "PA4", "PA5",
		"PA8", "PA9", "PA10", "PA11",
		"PA12", "PA13", "PA14", "PA15";
	function = "ncsi";
	drive-strength = <10>;
};

&ncsi_8bit_pins_b {
	pins = 	"PA7", "PA4", "PA5",
		"PA8", "PA9", "PA10", "PA11",
		"PA12", "PA13", "PA14", "PA15";
	function = "gpio_in";
};

&vind0 {
      csi_top = <300000000>;
      csi_isp = <300000000>;
      //vind_mclkpin-supply = <>; /* vcc-pe */
      //vind_mclkpin_vol = <1800000>;
      //vind_mcsipin-supply = <>;  /* vcc-mcsi */
      //vind_mcsipin_vol = <1800000>;
      //vind_mipipin-supply = <>;  /* vcc-pk */
      //vind_mipipin_vol = <1800000>;
      status = "okay";

      csi0: csi@5820000 {
	      status = "okay";
      };

      csi1: csi@5821000 {
	      status = "disabled";
      };

      csi2: csi@5822000 {
              pinctrl-names = "default","sleep";
              pinctrl-0 = <&ncsi_8bit_pins_a>;
              pinctrl-1 = <&ncsi_8bit_pins_b>;
              status = "disabled";
      };

      mipi0: mipi@5810100 {
	      pinctrl-names = "mipi0-1lane-default","mipi0-1lane-sleep",
				"mipi0-2lane-default","mipi0-2lane-sleep";
	      pinctrl-0 = <&mipia_1lane_pins_a>;
	      pinctrl-1 = <&mipia_1lane_pins_b>;
	      pinctrl-2 = <&mipia_2lane_pins_a>;
	      pinctrl-3 = <&mipia_2lane_pins_b>;
	      status = "okay";
      };

      mipi1: mipi@5810200 {
	      status = "disabled";
      };

      mipi2: mipi@5810300 {
	      status = "disabled";
      };

      tdm0:tdm@5908000 {
              work_mode = <0>;
              status = "okay";
      };

      isp00:isp@5900000 {
              work_mode = <0>;
              status = "okay";
      };

      isp01:isp@5902000 {
              status = "disabled";
      };

      isp10:isp@2 {
              status = "disabled";
      };

      isp20:isp@3 {
              status = "disabled";
      };

      scaler00:scaler@5910000 {
              work_mode = <0>;
              status = "okay";
      };

      scaler01:scaler@590fffc {
              status = "disabled";
      };

      scaler10:scaler@5910400 {
              work_mode = <0>;
              status = "disabled";
      };

      scaler11:scaler@59103fc {
              status = "disabled";
      };

      scaler20:scaler@8 {
              work_mode = <0>;
              status = "disabled";
      };

      actuator0: actuator@2108180 {
              device_type = "actuator0";
              actuator0_name = "cn3927_act";
              actuator0_slave = <0x18>;
              actuator0_af_pwdn = <>;
              actuator0_afvdd = "afvcc-csi";
              actuator0_afvdd_vol = <2800000>;
              status = "disabled";
      };

      flash0: flash@2108190 {
              device_type = "flash0";
              flash0_type = <2>;
              flash0_en = <>;
              flash0_mode = <>;
              flash0_flvdd = "";
              flash0_flvdd_vol = <>;
              device_id = <0>;
              status = "disabled";
      };

      sensor0:sensor@5812000 {
              device_type = "sensor0";
              sensor0_mname = "gc05a2_mipi";
              sensor0_twi_cci_id = <1>;
              sensor0_twi_addr = <0x6e>;
              sensor0_mclk_id = <0>;
              sensor0_pos = "rear";
              sensor0_isp_used = <1>;
              sensor0_fmt = <1>;
              sensor0_stby_mode = <0>;
              sensor0_vflip = <0>;
              sensor0_hflip = <0>;
              sensor0_power_en = <&pio PA 23 GPIO_ACTIVE_HIGH>;
              sensor0_reset = <&pio PG 9 GPIO_ACTIVE_LOW>;
              sensor0_pwdn = <&pio PE 8 GPIO_ACTIVE_HIGH>;
	      flash_handle = <&flash0>;
	      act_handle = <&actuator0>;
              status = "okay";
      };

      sensor1:sensor@5812010 {
              device_type = "sensor1";
              sensor1_mname = "nvp6158";
              sensor1_twi_cci_id = <5>;
              sensor1_twi_addr = <0x64>;
              sensor1_mclk_id = <2>;
              sensor1_pos = "front";
              sensor1_isp_used = <0>;
              sensor1_fmt = <0>;
              sensor1_stby_mode = <0>;
              sensor1_vflip = <0>;
              sensor1_hflip = <0>;
              sensor1_iovdd-supply = <>;
              sensor1_iovdd_vol = <>;
              sensor1_avdd-supply = <>;
              sensor1_avdd_vol = <>;
              sensor1_dvdd-supply = <>;
              sensor1_dvdd_vol = <>;
              sensor1_power_en = <>;
              sensor1_reset = <&pio PG 13 GPIO_ACTIVE_LOW>;
              sensor1_pwdn = <>;
              status = "disabled";
      };

      sensor_list0:sensor_list@200b820 {
              sensor00_mname = "gc5035_mipi";
              sensor00_twi_addr = <0x6c>;
              sensor00_type = <1>;
              sensor00_hflip =  <0>;
              sensor00_vflip = <0>;
              sensor00_act_used = <1>;
              sensor00_act_name = "dw9714_act";
              sensor00_act_twi_addr = <0x18>;
              sensor01_mname = "ov5675_mipi";
              sensor01_twi_addr = <0x6c>;
              sensor01_type = <1>;
              sensor01_hflip =  <0>;
              sensor01_vflip = <0>;
              sensor01_act_used = <1>;
              sensor01_act_name = "dw9714_act";
              sensor01_act_twi_addr = <0x18>;
              sensor02_mname = "sp5409_mipi";
              sensor02_twi_addr = <0x78>;
              sensor02_type = <1>;
              sensor02_hflip =  <0>;
              sensor02_vflip = <0>;
              sensor02_act_used = <1>;
              sensor02_act_name = "dw9714_act";
              sensor02_act_twi_addr = <0x18>;
              status  = "disabled";
      };

      sensor_list1:sensor_list@200b830 {
              sensor10_mname = "gc02m2_mipi";
              sensor10_twi_addr = <0x20>;
              sensor10_type = <1>;
              sensor10_hflip =  <0>;
              sensor10_vflip = <0>;
              sensor10_act_used = <0>;
              sensor10_act_name = "";
              sensor10_act_twi_addr = <>;
              sensor11_mname = "ov02a10_mipi";
              sensor11_twi_addr = <0x7a>;
              sensor11_type = <1>;
              sensor11_hflip =  <1>;
              sensor11_vflip = <0>;
              sensor11_act_used = <0>;
              sensor11_act_name = "";
              sensor11_act_twi_addr = <>;
              sensor12_mname = "gc030a_mipi";
              sensor12_twi_addr = <0x42>;
              sensor12_type = <1>;
              sensor12_hflip =  <0>;
              sensor12_vflip = <0>;
              sensor12_act_used = <0>;
              sensor12_act_name = "";
              sensor12_act_twi_addr = <>;
              status  = "disabled";
      };

      vinc00:vinc@5830000 {
              vinc0_csi_sel = <0>;
              vinc0_mipi_sel = <0>;
              vinc0_isp_sel = <0>;
              vinc0_isp_tx_ch = <0>;
              vinc0_tdm_rx_sel = <0xff>;
              vinc0_rear_sensor_sel = <0>;
              vinc0_front_sensor_sel = <0>;
              vinc0_sensor_list = <0>;
              device_id = <0>;
              work_mode = <0x0>;
              status = "okay";
      };

      vinc01:vinc@582fffc {
              vinc1_csi_sel = <1>;
              vinc1_mipi_sel = <1>;
              vinc1_isp_sel = <1>;
              vinc1_isp_tx_ch = <0>;
              vinc1_tdm_rx_sel = <1>;
              vinc1_rear_sensor_sel = <1>;
              vinc1_front_sensor_sel = <1>;
              vinc1_sensor_list = <0>;
              device_id = <1>;
              status = "disabled";
      };

      vinc10:vinc@5831000 {
              vinc4_csi_sel = <2>;
              vinc4_mipi_sel = <0xff>;
              vinc4_isp_sel = <2>;
              vinc4_isp_tx_ch = <0>;
              vinc4_tdm_rx_sel = <0>;
              vinc4_rear_sensor_sel = <1>;
              vinc4_front_sensor_sel = <1>;
              vinc4_sensor_list = <0>;
              device_id = <4>;
              work_mode = <0x0>;
              status = "okay";
      };

      vinc11:vinc@5830ffc {
              vinc5_csi_sel = <1>;
              vinc5_mipi_sel = <1>;
              vinc5_isp_sel = <1>;
              vinc5_isp_tx_ch = <0>;
              vinc5_tdm_rx_sel = <1>;
              vinc5_rear_sensor_sel = <1>;
              vinc5_front_sensor_sel = <1>;
              vinc5_sensor_list = <0>;
              device_id = <5>;
              status = "disabled";
      };

      vinc20:vinc@5832000 {
              vinc8_csi_sel = <2>;
              vinc8_mipi_sel = <0xff>;
              vinc8_isp_sel = <2>;
              vinc8_isp_tx_ch = <0>;
              vinc8_tdm_rx_sel = <0>;
              vinc8_rear_sensor_sel = <1>;
              vinc8_front_sensor_sel = <1>;
              vinc8_sensor_list = <0>;
              device_id = <8>;
              work_mode = <0x0>;
              status = "disabled";
      };
};


