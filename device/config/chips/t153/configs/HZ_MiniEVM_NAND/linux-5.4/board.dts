&soc {
	e907_rproc: e907_rproc@1a00000 {
		mboxes = <&msgbox 0>, <&msgbox 2>;
		mbox-names = "arm-kick", "arm-standby";
		memory-region = <&rv_vdev0buffer>, <&rv_vdev0vring0>, <&rv_vdev0vring1>, <&e907_dram_reserved>;
		fw-region = <&e907_mem_fw>;
		fw-partitions = "riscv0", "riscv0-r";
		fw-partition-sectors = <2048>;
		memory-mappings =
			/* < DA      len        PA >	*/
			/* SRAM A2 */
			< 0x40000    0x2BFFF    0x40000 >,
			/* SHARED SRAM */
			< 0x1000000  0x7ffff    0x1000000 >,
			/* DRAM SPACE1 */
			< 0x40000000 0x3f000000 0x40000000>,
			/* DRAM SPACE2 */
			< 0x80000000 0x3f000000 0x80000000>,
			/* DRAM SPACE3 */
			< 0xC0000000 0x3f000000 0xC0000000>;
		standby-ctrl-en = <0x1>;
		standby-record-reg = <0x07090114>;
		share-irq = "e907";
		//auto-boot;
		status = "okay";
		rproc_wdt: rproc_wdt@0 {
			timeout_ms = <6000>;
			try_times = <3>;
			reset_type = <0x2>;
			status="okay";
		};
	};

	gpio-keys {
		compatible = "gpio-keys";
		status = "disabled";

		power {
			label = "Power Button";
			linux,code = <KEY_POWER>;
			debounce-interval = <20>;
			//gpios = <&rtc_pio PW 1 GPIO_ACTIVE_HIGH>;
		};

		volume-up {
			label = "Volume Up";
			linux,code = <KEY_VOLUMEUP>;
			debounce-interval = <20>;
			//gpios = <&rtc_pio PW 2 GPIO_ACTIVE_HIGH>;
		};

		volume-down {
			label = "Volume Down";
			linux,code = <KEY_VOLUMEDOWN>;
			debounce-interval = <20>;
			//gpios = <&rtc_pio PW 3 GPIO_ACTIVE_HIGH>;
		};
	};

	auto_print@54321 {
		reg = <0x0 0x54321 0x0 0x0>;
		device_type = "auto_print";
		status = "okay";
	};

	mailbox_test: mailbox_test@0 {
		compatible = "core0-mailbox-test";
		mboxes = <&msgbox_core0 7>;
		mbox-names = "tx|rx0";
		status = "okay";
	};
};

&spi0 {
	pinctrl-0 = <&spi0_pins_default &spi0_pins_cs>;
	pinctrl-1 = <&spi0_pins_sleep>;
	pinctrl-names = "default", "sleep";
	sunxi,spi-bus-mode = <SUNXI_SPI_BUS_NAND>;
	sunxi,spi-cs-mode = <SUNXI_SPI_CS_SOFT>;
	status = "okay";

	spi-nand@0 {
		#address-cells = <1>;
		#size-cells = <1>;
		compatible = "spi-nand";
		reg = <0x0>;
		spi-max-frequency = <20000000>;
		spi-rx-bus-width=<0x01>;
		spi-tx-bus-width=<0x01>;
		model = "DS35X2GBXXX";
		id-0 = <0xffffffff>;
		id-1 = <0xe5b2ffff>;
		die_cnt_per_chip = <1>;
		blk_cnt_per_die = <2048>;
		page_cnt_per_blk = <64>;
		sect_cnt_per_page = <4>;
		oob_size_per_page = <64>;
		bad_block_mark_pos = "first_2_page";	// BAD_BLK_FLAG_FIRST_2_PAGE
		max_erase_times = <65000>;
		ecc_type = <9>;	// BIT3_LIMIT5_ERR2
		ecc_protected_type = <1>;	// SIZE16_OFF0_LEN16
		//read_from_cache_x4_not_need_enable = "yes";
		//read_from_cache_need_onedummy = "yes";
		//ecc_flag = <>;	//BIT(0),BIT(1)
		ecc_status_shift = <0>;	// not sure ,mybe 4
		status="okay";
	};
};

