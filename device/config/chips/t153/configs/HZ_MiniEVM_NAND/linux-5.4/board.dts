	rgb_panel0: rgb_panel@1 {
		compatible = "sunxi-rgb";
		status = "disabled";
		reg = <0>;
		backlight = <&backlight0>;
		display-timings {
			native-mode = <&rgb0_timing0>;
			rgb0_timing0: timing0 {
				clock-frequency = <29232000>;
				hback-porch = <40>;
				hactive = <800>;
				hfront-porch = <40>;
				hsync-len = <48>;
				vback-porch = <29>;
				vactive = <480>;
				vfront-porch = <13>;
				vsync-len = <3>;
			};
		};
		port {
			rgb0_panel_in: endpoint {
				remote-endpoint = <&rgb0_panel_out>;
			};
		};
	};

	can0 {
		compatible = "allwinner,sun8i-t153-can";
		reg = <0x0 0x0453C800 0x0 0x400>,
			<0x0 0x04538000 0x0 0x4400>,
			<0x0 0x04530000 0x0 0x1000>,
			<0x0 0x04534000 0x0 0x1000>;
		reg-names = "can", "message_ram", "can_top", "can_dma";
		interrupts = <GIC_SPI 36 IRQ_TYPE_LEVEL_HIGH>, <GIC_SPI 35 IRQ_TYPE_LEVEL_HIGH>, <GIC_SPI 37 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "int0", "int_top", "int1";
		clocks = <&ccu CLK_CAN0>, <&ccu CLK_BUS_CAN0>, <&ccu CLK_MBUS_CAN_GATE>;
		clock-names = "can_clk", "can_bus", "can_mbus";
		resets = <&ccu RST_BUS_CAN0>, <&ccu RST_BUS_CAN_SYS>;
		reset-names = "can_rst", "can_sys_rst";
		clock-frequency = <40000000>;
		allwinner,ram-cfg = <0x0 0 0 64 64 64 32 32>;
		pinctrl-0 = <&can0_pins_active>;
		pinctrl-1 = <&can0_pins_sleep>;
		pinctrl-names = "default", "sleep";
		// status = "okay";
		status = "disabled"; // Modfiy by MHY
	};

	can1 {
		compatible = "allwinner,sun8i-t153-can";
		reg = <0x0 0x04541800 0x0 0x400>,
				<0x0 0x0453D000 0x0 0x4400>,
				<0x0 0x04531000 0x0 0x1000>,
				<0x0 0x04535000 0x0 0x1000>;
		reg-names = "can", "message_ram", "can_top", "can_dma";
		interrupts = <GIC_SPI 144 IRQ_TYPE_LEVEL_HIGH>, <GIC_SPI 146 IRQ_TYPE_LEVEL_HIGH>, <GIC_SPI 145 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "int0", "int_top", "int1";
		clocks = <&ccu CLK_CAN1>, <&ccu CLK_BUS_CAN1>, <&ccu CLK_MBUS_CAN_GATE>;
		clock-names = "can_clk", "can_bus", "can_mbus";
		resets = <&ccu RST_BUS_CAN1>, <&ccu RST_BUS_CAN_SYS>;
		reset-names = "can_rst", "can_sys_rst";
		clock-frequency = <40000000>;
		allwinner,ram-cfg = <0x0 0 0 64 64 64 32 32>;
		pinctrl-0 = <&can1_pins_active>;
		pinctrl-1 = <&can1_pins_sleep>;
		pinctrl-names = "default", "sleep";
		// status = "okay";
		status = "disabled"; // Modfiy by MHY
	};
};

&pio {
	uart0_pins_active: uart0_pins@0 {
		pins = "PB9", "PB10";
		function = "uart0";
	};

	uart0_pins_sleep: uart0_pins@1 {
		pins = "PB9", "PB10";
		function = "io_disabled";
	};

	uart1_pins_active: uart1_pins@0 {
		pins = "PG6", "PG7", "PG8", "PG9";
		function = "uart1";
		drive-strength = <10>;
		bias-pull-up;
	};

	uart1_pins_sleep: uart1_pins@1 {
		pins = "PG6", "PG7", "PG8", "PG9";
		function = "gpio_in";
	};

	uart2_pins_active: uart2_pins@0 {
		pins = "PD2", "PD3", "PD1", "PD0";
		function = "uart2";
	};

	uart2_pins_sleep: uart2_pins@1 {
		pins = "PD2", "PD3", "PD1", "PD0";
		function = "io_disabled";
	};

	uart3_pins_active: uart3_pins@0 {
		pins = "PD14", "PD15", "PD16", "PD17";
		function = "uart3";
	};

	uart3_pins_sleep: uart3_pins@1 {
		pins = "PD14", "PD15", "PD16", "PD17";
		function = "io_disabled";
	};

	uart4_pins_active: uart4_pins@0 {
		pins = "PD6", "PD7", "PD5", "PD4";
		function = "uart4";
	};

	uart4_pins_sleep: uart4_pins@1 {
		pins = "PD6", "PD7", "PD5", "PD4";
		function = "io_disabled";
	};

	uart5_pins_active: uart5_pins@0 {
		pins = "PC9", "PC10", "PC11", "PC8";
		function = "uart5";
	};

	uart5_pins_sleep: uart5_pins@1 {
		pins = "PC9", "PC10", "PC11", "PC8";
		function = "io_disabled";
	};

	uart6_pins_active: uart6_pins@0 {
		pins = "PA14", "PA15", "PE5", "PE6";
		function = "uart6";
	};

	uart6_pins_sleep: uart6_pins@1 {
		pins = "PA14", "PA15", "PE5", "PE6";
		function = "io_disabled";
	};
/*
	uart7_pins_active: uart7_pins@0 {
		pins = "PB13", "PB14", "PB11", "PB12";
		function = "uart7";
	};

	uart7_pins_sleep: uart7_pins@1 {
		pins = "PB13", "PB14", "PB11", "PB12";
		function = "io_disabled";
	};
*/

	uart7_pins_active: uart7_pins@0 {
		pins = "PJ4", "PJ5";
		function = "uart7";
	};

	uart7_pins_sleep: uart7_pins@1 {
		pins = "PJ4", "PJ5";
		function = "io_disabled";
	};

	uart8_pins_active: uart8_pins@0 {
		pins = "PD10", "PD11", "PD12", "PD13";
		function = "uart8";
	};

	uart8_pins_sleep: uart8_pins@1 {
		pins = "PD10", "PD11", "PD12", "PD13";
		function = "io_disabled";
	};

	uart9_pins_active: uart9_pins@0 {
		pins = "PD0", "PD1", "PD2", "PD3";
		function = "uart9";
	};

	uart9_pins_sleep: uart9_pins@1 {
		pins = "PD0", "PD1", "PD2", "PD3";
		function = "io_disabled";
	};

	/* CAN0 */
	can0_pins_active: can0_pins@0 {
		pins = "PJ12", "PJ13";
		function = "uart9";
	};

	can0_pins_sleep: can0_pins@1 {
		pins = "PJ12", "PJ13";
		function = "io_disabled";
	};

	/* CAN1 */
	can1_pins_active: can1_pins@0 {
		pins = "PJ14", "PJ15";
		function = "uart9";
	};

	can1_pins_sleep: can1_pins@1 {
		pins = "PJ14", "PJ15";
		function = "io_disabled";
	};

	spi0_pins_default: spi0@0 {
		pins = "PC0", "PC2", "PC3"; /* clk, mosi, miso */
		function = "spi0";
		drive-strength = <20>;
	};

	spi0_pins_cs: spi0@1 {
		pins = "PC1", "PC4", "PC5"; /* cs, wp, hold */
		function = "spi0";
		drive-strength = <20>;
		bias-pull-up;
	};

	spi0_pins_sleep: spi0@3 {
		pins = "PC0", "PC1", "PC2", "PC3", "PC4", "PC5";
		function = "gpio_in";
		drive-strength = <10>;
	};

	spi3_pins_default: spi1@0 {
		pins = "PB1", "PB2", "PB3"; /* clk, mosi, miso */
		function = "spi3";
		drive-strength = <10>;
	};

	spi3_pins_cs: spi1@1 {
		pins = "PB0"; /* cs, wp, hold */
		function = "spi3";
		drive-strength = <10>;
		bias-pull-up;
	};

	spi3_pins_sleep: spi1@2 {
		pins = "PB0", "PB1", "PB2", "PB3";
		function = "gpio_in";
		drive-strength = <10>;
	};

	twi1_pins_default: twi1@0 {
		pins = "PE1", "PE2";
		function = "twi1";
		drive-strength = <10>;
		bias-pull-up;
	};

	twi1_pins_sleep: twi1@1 {
		pins = "PE1", "PE2";
		function = "gpio_in";
	};


	twi2_pins_default: twi2@0 {
		pins = "PK7", "PK8";
		function = "twi2";
		drive-strength = <10>;
		bias-pull-up;
	};

	twi2_pins_sleep: twi2@1 {
		pins = "PK7", "PK8";
		function = "gpio_in";
	};
#if 0
	twi5_pins_default: twi5@0 {
		pins = "PD20", "PD21";
		function = "twi5";
		drive-strength = <10>;
		bias-pull-up;
	};

	twi5_pins_sleep: twi5@1 {
		pins = "PD20", "PD21";
		function = "gpio_in";
	};
#endif
	twi5_pins_default: twi5@0 {
		pins = "PD18", "PD19";
		function = "twi5";
		drive-strength = <10>;
		bias-pull-up;
	};

	twi5_pins_sleep: twi5@1 {
		pins = "PD18", "PD19";
		function = "gpio_in";
	};


	pwmcs0_0_pins_active: pwmcs0_0@0 {
		pins = "PB8";
		function = "pwm0_0";
		drive-strength = <20>;
	};

	pwmcs0_0_pins_sleep: pwmcs0_0@1 {
		pins = "PB8";
		function = "gpio_in";
		bias-pull-down;
	};

	pwmcs0_4_pins_active: pwmcs0_4@0 {
		pins = "PB13";
		function = "pwm0_4";
		drive-strength = <20>;
	};

	pwmcs0_4_pins_sleep: pwmcs0_4@1 {
		pins = "PB13";
		function = "gpio_in";
		bias-pull-down;
	};

	gpadc0_pins_default: gpadc0@0 {
		pins = "PA4", "PA5", "PA6", "PA7", "PA8", "PA9", "PA10", "PA11", "PA12", "PA13";
		function = "gpadc0";
	};

	gpadc0_pins_sleep: gpadc0@1 {
		pins = "PA4", "PA5", "PA6", "PA7", "PA8", "PA9", "PA10", "PA11", "PA12", "PA13";
		function = "gpio_in";
	};

	gpadc1_pins_default: gpadc1@0 {
		pins = "PA14","PA15";
		function = "gpadc1";
	};

	gpadc2_pins_sleep: gpadc2@1 {
		pins = "PA0", "PA1", "PA2", "PA3";
		function = "gpio_in";
	};

	gpadc2_pins_default: gpadc2@0 {
		pins = "PA0","PA1", "PA2", "PA3";
		function = "gpadc2";
	};

	gpadc1_pins_sleep: gpadc1@1 {
		pins = "PA14", "PA15";
		function = "gpio_in";
	};


	irrx0_pins_default: irrx0@0 {
		pins = "PJ12";
		function = "ir0";
	};

	irrx0_pins_sleep: irrx0@1 {
		pins = "PJ12";
		function = "gpio_in";
	};

	irrx1_pins_default: irrx1@0 {
		pins = "PJ13";
		function = "ir1";
	};

	irrx1_pins_sleep: irrx1@1 {
		pins = "PJ13";
		function = "gpio_in";
	};

	irrx2_pins_default: irrx2@0 {
		pins = "PJ14";
		function = "ir2";
	};

	irrx2_pins_sleep: irrx2@1 {
		pins = "PJ14";
		function = "gpio_in";
	};

	irrx3_pins_default: irrx3@0 {
		pins = "PJ15";
		function = "ir3";
	};

	irrx3_pins_sleep: irrx3@1 {
		pins = "PJ15";
		function = "gpio_in";
	};

	irtx0_pins_default: irtx@0 {
		pins = "PJ9";
		function = "ir";
	};

	irtx0_pins_sleep: irtx@1 {
		pins = "PJ9";
		function = "gpio_in";
	};

	dmic_pins_a: dmic@0 {
		/* DMIC_PIN: CLK, DATA0, DATA1, DATA2 */
		pins = "PF2", "PF3", "PF4", "PF5";
		function = "dmic";
		drive-strength = <10>;
		bias-disable;
	};

	dmic_pins_b: dmic@1 {
		pins = "PF2", "PF3", "PF4", "PF5";
		function = "io_disabled";
		drive-strength = <10>;
		bias-disable;
	};

	ledc_pins_default: ledc@0 {
		pins = "PJ8";
		function = "ledc";
		drive-strength = <20>;
	};

	ledc_pins_sleep: ledc@1 {
		pins = "PJ8";
		function = "gpio_in";
	};

	gmac0_pins_default: gmac0@0 {
		pins = "PA4", "PA5", "PA6",
			"PA8", "PA9", "PA10", "PA11",
			"PA12", "PA13", "PA15", "PA16", 
			"PA17", "PA18", "PA19";
		function = "rgmii0";
		drive-strength = <40>;
		bias-pull-up;
	};

	gmac0_pins_sleep: gmac0@1 {
		pins = "PA4", "PA5", "PA6", 
			"PA8", "PA9", "PA10", "PA11",
			"PA12", "PA13", "PA15", "PA16", 
			"PA17", "PA18", "PA19";
		function = "io_disabled";
	};

	gmac1_pins_default: gmac1@0 {
		pins = "PG0", "PG1", "PG2", "PG3", 
			"PG4", "PG6", "PG7", "PG8", 
			"PG10", "PG11", "PG12", 
			"PG13", "PG14", "PG15";
		function = "rgmii1";
		drive-strength = <40>;
		bias-pull-up;
	};

	gmac1_pins_sleep: gmac1@1 {
		pins = "PG0", "PG1", "PG2", "PG3", "PG4", "PG6", "PG7",
			"PG8", "PG10", "PG11", "PG12", "PG13", "PG14", "PG15";
		function = "io_disabled";
	};

	rtp_pins_default: rtp@0 {
		pins = "PA0", "PA1", "PA2", "PA3";
		function = "tp";
	};

	rtp_pins_sleep: rtp@1 {
		pins = "PA0", "PA1", "PA2", "PA3";
		function = "gpio_in";
	};
};

&lvds0 {
	status = "disabled";
	dual-channel = <0>;
	ports {
		#address-cells = <1>;
		#size-cells = <0>;
		port@1 {
			#address-cells = <1>;
			#size-cells = <0>;
			reg = <1>;
			lvds_panel_out: endpoint@0 {
				#address-cells = <1>;
				#size-cells = <0>;
				reg = <0>;
				remote-endpoint = <&lvds_panel_in>;
			};
			lvds_panel_out1: endpoint@1 {
			};
		};
	};
};

&dsi0_4lane_pins_a {
	pins = "PD0", "PD1", "PD2", "PD3", "PD4", "PD5", "PD6", "PD7", "PD8", "PD9";
	function = "dsi";
	drive-strength = <30>;
	bias-disable;
};

&dsi0_4lane_pins_b {
	pins = "PD0", "PD1", "PD2", "PD3", "PD4", "PD5", "PD6", "PD7", "PD8", "PD9";
	function = "io_disabled";
	bias-disable;
};

&dsi0 {
	status = "okay";
	pinctrl-0 = <&dsi0_4lane_pins_a>;
	pinctrl-1 = <&dsi0_4lane_pins_b>;
	pinctrl-names = "active","sleep";

	panel: panel@0 {
		compatible = "allwinner,virtual-panel";
		status = "okay";
		reg = <0>;

//		power-delay-ms = <10>;
//		power0-supply = <&reg_dcdc4>;
//		power1-supply = <&reg_cldo1>;

		reset-num = <1>;
		reset-delay-ms = <60>;
//		backlight = <&backlight0>;
		dsi,flags = <(MIPI_DSI_MODE_VIDEO)>;
		dsi,lanes = <4>;
		dsi,format = <0>; // 0:MIPI_DSI_FMT_RGB888
		panel-init-sequence = [
		];

		panel-exit-sequence = [
		];

		display-timings {
			native-mode = <&timing0>;
			timing0: timing0 {
				clock-frequency = <148500000>;
				hback-porch = <148>;
				hactive = <1920>;
				hfront-porch = <88>;
				hsync-len = <44>;
				vback-porch = <36>;
				vactive = <1080>;
				vfront-porch = <4>;
				vsync-len = <5>;
			};
		};

		port@0 {
			reg = <0>;
			panel_in_dsi: endpoint {
				remote-endpoint = <&dsi0_out_panel>;
			};
		};
	};

	ports {
		port@1 {
			reg = <1>;
			dsi0_out_panel:endpoint {
				remote-endpoint = <&panel_in_dsi>;
			};
		};
	};
};

&rgb0 {
	status = "disabled";
	pinctrl-0 = <&rgb0_24pins_a>;
	pinctrl-1 = <&rgb0_24pins_b>;
	pinctrl-names = "active","sleep";
	ports {
		port@1 {
			#address-cells = <1>;
			#size-cells = <0>;
			reg = <1>;
			rgb0_panel_out: endpoint@0 {
				reg = <0>;
				remote-endpoint = <&rgb0_panel_in>;
			};
			rgb1_panel_out: endpoint@1 {
			};
		};
	};
};

